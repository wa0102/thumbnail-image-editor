@{
    ViewData["Title"] = "画像切り抜き";
}

<div class="container py-5">
    <h1 class="display-4 font-weight-bold k-font text-center mb-3">画像切り抜き</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success text-center shadow-sm mb-4">
            @TempData["Message"]
        </div>
    }

    <div id="beforeText">
        <p class="text-center">
            画像を切り抜き背景を透過することができます😄<br />
            また、下記の「切り抜き開始」してから簡易的にサムネイルを作成することができます!!!<br />
            ※「切り抜き開始」をクリックすると自動的に背景が透過された状態で画像が保存されます🎉
        </p>
    </div>

    <div id="afterText" style="display:none;">
        <p class="text-center">
            「背景色」で単色で背景を決めるか「背景画像」でファイルを選択して背景にすることが可能😄<br />
            透過した画像はクリックすると移動でき、マウスホイールで縮小拡大も可能👍<br />
            「追加画像」で画像を追加し、マウスホイールで縮小拡大・Deleteキーで削除も可能<br />
            完成したら、「背景と合成して保存」で保存してね😄👍
        </p>
    </div>

    <!-- 背景選択 -->
    <div id="backgroundControls" style="display:none;text-align:center;margin-bottom:10px;">
        背景色: <input type="color" id="bgColor" value="#add8e6">
        背景画像: <input type="file" id="bgImage" accept="image/*">
        <button type="button" id="clearBgBtn">背景画像削除</button>
        <br>
        追加画像: <input type="file" id="addImage" accept="image/*" multiple>
    </div>

    <!-- 文字操作 -->
    <div id="textControls" style="display:none;text-align:center;margin-bottom:10px;">
        <input type="text" id="textInput" placeholder="文字を入力" />
        <input type="color" id="textColor" value="#000000" />
        <input type="number" id="textSize" value="24" style="width:60px;" />px
        <select id="textFont"></select>

        <div style="margin-top:5px;">
            回転
            <button type="button" id="rotMinus">▼</button>
            <button type="button" id="rotPlus">▲</button>
            <span id="rotateValue">0°</span>
        </div>

        <div style="margin-top:5px;">
            <label><input type="checkbox" id="strokeEnable"> 縁取り</label><br>
            <input type="color" id="strokeColor" value="#000000">
            <input type="number" id="strokeWidth" value="2" style="width:50px;">px
        </div>

        <div style="margin-top:5px;">
            <label><input type="checkbox" id="stroke2Enable"> 2重縁取り</label><br>
            <input type="color" id="stroke2Color" value="#ffffff">
            <input type="number" id="stroke2Width" value="4" style="width:50px;">px
        </div>

        <button id="addTextBtn" class="btn btn-primary btn-sm">文字追加</button>
        <button id="deleteTextBtn" class="btn btn-danger btn-sm">削除</button>
    </div>

    <div id="background" style="display:none;">
        @if (ViewBag.ThumbImageUrl != null)
        {
            <img id="foreground" src="@ViewBag.ThumbImageUrl">
        }
    </div>

    <div class="text-center mt-2" style="display:none;" id="flipBtnContainer">
        <button id="flipBtn" class="btn btn-warning btn-sm">画像反転</button>
    </div>

    <div class="text-center mt-3" id="saveBtnContainer" style="display:none;">
        <button id="saveBtn" class="btn btn-success">背景と合成して保存</button>
    </div>

    <div class="card mx-auto mt-4" style="max-width:500px;">
        <div class="card-body">
            <form asp-controller="Home" asp-action="Index" method="post" enctype="multipart/form-data">
                <input type="file" name="image" class="form-control mb-3">
                <button class="btn btn-danger w-100">切り抜き開始</button>
            </form>
        </div>
    </div>
</div>

<style>
    #background {
        width: 1280px;
        height: 720px;
        margin: auto;
        position: relative;
        background: lightblue;
        overflow: hidden;
    }

    #foreground, .added-image {
        position: absolute;
        top: 50px;
        left: 50px;
        width: 200px;
        cursor: grab;
    }

    .text-item {
        position: absolute;
        cursor: grab;
        user-select: none;
        white-space: pre;
        transform-origin: left top;
    }
</style>

<script>
    const bg = document.getElementById("background");
    const fg = document.getElementById("foreground");
    const rotateValue = document.getElementById("rotateValue");
    const textFont = document.getElementById("textFont");
    const bgColor = document.getElementById("bgColor");
    const bgImage = document.getElementById("bgImage");
    const clearBgBtn = document.getElementById("clearBgBtn");
    const addImage = document.getElementById("addImage");
    const flipBtn = document.getElementById("flipBtn");
    const flipBtnContainer = document.getElementById("flipBtnContainer");

    let selectedText = null;
    let selectedImg = null;
    let bgImgData = null;
    let dragTarget = null;
    let startX=0, startY=0, startLeft=0, startTop=0;
    let flipState = new Map(); // 反転状態保持

    /* フォント取得 */
    const fonts = ["Arial","Verdana","Tahoma","Times New Roman","Courier New",
                   "Georgia","Impact","Comic Sans MS","Trebuchet MS","Lucida Console"];
    fonts.forEach(f=>{
        const o=document.createElement("option"); o.value=o.textContent=f; textFont.appendChild(o);
    });
    document.fonts?.ready.then(()=>{
        const set=new Set();
        document.fonts.forEach(f=>set.add(f.family));
        set.forEach(f=>{
            if(!fonts.includes(f)){
                const o=document.createElement("option"); o.value=o.textContent=f; textFont.appendChild(o);
            }
        });
    });

    /* 初期表示 */
    window.addEventListener("DOMContentLoaded", ()=>{
        if(fg){
            background.style.display="block";
            textControls.style.display="block";
            saveBtnContainer.style.display="block";
            backgroundControls.style.display="block";
            afterText.style.display="block";
            beforeText.style.display="none";
            flipBtnContainer.style.display="block";
            enableDragScale(fg);
        }
    });

    /* 文字・画像ドラッグ＆拡大縮小 */
    function enableDragScale(el){
        el.dataset.scale = el.dataset.scale || 1;
        el.addEventListener("mousedown", e=>{
            dragTarget = el;
            startX = e.clientX; startY = e.clientY;
            startLeft = parseInt(el.style.left)||50;
            startTop = parseInt(el.style.top)||50;
            selectedText = el.classList.contains("text-item") ? el : null;
            selectedImg = el.classList.contains("added-image") || el.id==="foreground" ? el : null;
            flipBtnContainer.style.display = selectedImg ? 'block':'none';
        });
        el.addEventListener("wheel", e=>{
            e.preventDefault();
            let scale=parseFloat(el.dataset.scale);
            scale = Math.max(0.1, scale + (e.deltaY<0 ? 0.05:-0.05));
            el.dataset.scale=scale;
            let rotate=el.dataset.rotate||0;
            const flipped = flipState.get(el) || false;
            el.style.transform = `scale(${scale * (flipped?-1:1)},${scale}) rotate(${rotate}deg)`;
        });
        el.addEventListener("click", ()=>{
            selectedText = el.classList.contains("text-item") ? el : null;
            selectedImg = el.classList.contains("added-image") || el.id==="foreground" ? el : null;
            flipBtnContainer.style.display = selectedImg ? 'block':'none';
        });
    }

    /* Deleteキーで透過画像は削除不可 */
    document.addEventListener("keydown", e=>{
        if(e.key === "Delete" && selectedImg){
            if(selectedImg.id !== "foreground"){
                selectedImg.remove();
                selectedImg=null;
            }
        }
    });

    document.addEventListener("mousemove", e=>{
        if(!dragTarget) return;
        dragTarget.style.left = startLeft + (e.clientX-startX) + "px";
        dragTarget.style.top = startTop + (e.clientY-startY) + "px";
    });

    document.addEventListener("mouseup", ()=>{ dragTarget=null; });

    /* 背景操作 */
    bgColor.addEventListener("input", ()=>{ bg.style.background=bgColor.value; });
    bgImage.addEventListener("change", e=>{
        const file=e.target.files[0];
        if(file){
            const reader=new FileReader();
            reader.onload=evt=>{
                bgImgData = new Image(); bgImgData.src=evt.target.result;
                bg.style.backgroundImage=`url(${evt.target.result})`; bg.style.backgroundSize="cover";
            };
            reader.readAsDataURL(file);
        }
    });
    clearBgBtn.addEventListener("click", ()=>{ bgImgData=null; bg.style.backgroundImage="none"; });

    addImage.addEventListener("change", e=>{
        Array.from(e.target.files).forEach(file=>{
            const reader = new FileReader();
            reader.onload=evt=>{
                const img=document.createElement("img");
                img.src=evt.target.result;
                img.className="added-image"; img.style.left="50px"; img.style.top="50px";
                bg.appendChild(img); enableDragScale(img);
            };
            reader.readAsDataURL(file);
        });
    });

    /* 文字追加・縁取り */
    function applyStrokeStyle(d){
        let shadows=[];
        if(d.dataset.strokeEnable==="true"){
            const s1=parseInt(d.dataset.strokeWidth||2);
            const c1=d.dataset.strokeColor||"#000000";
            for(let x=-s1;x<=s1;x++){
                for(let y=-s1;y<=s1;y++){
                    if(x!==0 || y!==0) shadows.push(`${x}px ${y}px ${c1}`);
                }
            }
        }
        if(d.dataset.stroke2Enable==="true"){
            const s2=parseInt(d.dataset.stroke2Width||4);
            const c2=d.dataset.stroke2Color||"#ffffff";
            for(let x=-s2;x<=s2;x++){
                for(let y=-s2;y<=s2;y++){
                    if(x!==0 || y!==0) shadows.push(`${x}px ${y}px ${c2}`);
                }
            }
        }
        d.style.textShadow=shadows.join(",");
    }

    addTextBtn.onclick=()=>{
        const d=document.createElement("div");
        d.className="text-item"; d.textContent=textInput.value||"テキスト";
        d.style.left="50px"; d.style.top="50px";
        d.style.color=textColor.value; d.style.fontSize=textSize.value+"px";
        d.style.fontFamily=textFont.value; d.dataset.rotate=0; d.dataset.scale=1;
        d.dataset.strokeEnable=strokeEnable.checked; d.dataset.strokeColor=strokeColor.value;
        d.dataset.strokeWidth=strokeWidth.value; d.dataset.stroke2Enable=stroke2Enable.checked;
        d.dataset.stroke2Color=stroke2Color.value; d.dataset.stroke2Width=stroke2Width.value;
        bg.appendChild(d); enableDragScale(d); selectText(d); applyStrokeStyle(d);
    };

    function selectText(d){
        selectedText=d; selectedImg=null;
        rotateValue.textContent=d.dataset.rotate+"°";
        textInput.value=d.textContent;
        textColor.value=d.style.color;
        textSize.value=parseInt(d.style.fontSize);
        textFont.value=d.style.fontFamily;
        strokeEnable.checked=d.dataset.strokeEnable==="true";
        strokeColor.value=d.dataset.strokeColor||"#000000";
        strokeWidth.value=d.dataset.strokeWidth||2;
        stroke2Enable.checked=d.dataset.stroke2Enable==="true";
        stroke2Color.value=d.dataset.stroke2Color||"#ffffff";
        stroke2Width.value=d.dataset.stroke2Width||4;
    }

    rotPlus.onclick=()=>rotate(5); rotMinus.onclick=()=>rotate(-5);
    function rotate(v){
        if(!selectedText) return;
        selectedText.dataset.rotate=parseInt(selectedText.dataset.rotate)+v;
        rotateValue.textContent=selectedText.dataset.rotate+"°";
        selectedText.style.transform=`scale(${selectedText.dataset.scale}) rotate(${selectedText.dataset.rotate}deg)`;
    }

    [strokeEnable,strokeColor,strokeWidth,stroke2Enable,stroke2Color,stroke2Width].forEach(el=>{
        el.addEventListener("input", ()=>{
            if(selectedText){
                selectedText.dataset.strokeEnable=strokeEnable.checked;
                selectedText.dataset.strokeColor=strokeColor.value;
                selectedText.dataset.strokeWidth=strokeWidth.value;
                selectedText.dataset.stroke2Enable=stroke2Enable.checked;
                selectedText.dataset.stroke2Color=stroke2Color.value;
                selectedText.dataset.stroke2Width=stroke2Width.value;
                applyStrokeStyle(selectedText);
            }
        });
    });

    deleteTextBtn.onclick=()=>{
        if(selectedText){ selectedText.remove(); selectedText=null; }
        if(selectedImg && selectedImg.id !== "foreground"){ selectedImg.remove(); selectedImg=null; }
    };

    textInput.oninput = () => { if(selectedText) selectedText.textContent=textInput.value; };
    textColor.oninput = () => { if(selectedText) selectedText.style.color=textColor.value; };
    textSize.oninput = () => { if(selectedText) selectedText.style.fontSize=textSize.value+"px"; };
    textFont.onchange = () => { if(selectedText) selectedText.style.fontFamily=textFont.value; };

    /* 反転ボタン */
    flipBtn.onclick = ()=>{
        if(selectedImg){
            const current = flipState.get(selectedImg) || false;
            const scaleX = current ? 1 : -1;
            const scaleY = 1;
            const rotate = selectedImg.dataset.rotate || 0;
            const scale = selectedImg.dataset.scale || 1;
            selectedImg.style.transform = `scale(${scale*scaleX},${scaleY*scale}) rotate(${rotate}deg)`;
            flipState.set(selectedImg,!current);
        }
    };

    /* 保存時に反転状態を反映 */
    saveBtn.onclick=()=>{
        const c=document.createElement("canvas"); c.width=1280; c.height=720;
        const ctx=c.getContext("2d");
        ctx.fillStyle=bgColor.value; ctx.fillRect(0,0,c.width,c.height);
        if(bgImgData) ctx.drawImage(bgImgData,0,0,c.width,c.height);
        const fr=fg.getBoundingClientRect(); const br=bg.getBoundingClientRect();
        // foreground 反転反映
        const fgFlip = flipState.get(fg) || false;
        ctx.save();
        ctx.translate(fr.left-br.left + fr.width/2, fr.top-br.top + fr.height/2);
        ctx.scale(fgFlip?-1:1,1);
        ctx.drawImage(fg,-fr.width/2,-fr.height/2,fr.width,fr.height);
        ctx.restore();

        // 追加画像も反映
        bg.querySelectorAll(".added-image").forEach(img=>{
            const r=img.getBoundingClientRect();
            const imgFlip = flipState.get(img) || false;
            ctx.save();
            ctx.translate(r.left-br.left + r.width/2, r.top-br.top + r.height/2);
            ctx.scale(imgFlip?-1:1,1);
            ctx.drawImage(img,-r.width/2,-r.height/2,r.width,r.height);
            ctx.restore();
        });

        // テキスト描画
        bg.querySelectorAll(".text-item").forEach(t=>{
            const s=getComputedStyle(t);
            ctx.save();
            ctx.translate(parseInt(t.style.left),parseInt(t.style.top));
            ctx.rotate(t.dataset.rotate*Math.PI/180);
            ctx.scale(t.dataset.scale,t.dataset.scale);
            ctx.font=`${s.fontSize} ${s.fontFamily}`;
            if(t.dataset.strokeEnable==="true" && t.dataset.stroke2Enable==="true"){
                ctx.lineWidth=parseInt(t.dataset.stroke2Width); ctx.strokeStyle=t.dataset.stroke2Color;
                ctx.strokeText(t.textContent,0,parseInt(s.fontSize));
                ctx.lineWidth=parseInt(t.dataset.strokeWidth); ctx.strokeStyle=t.dataset.strokeColor;
                ctx.strokeText(t.textContent,0,parseInt(s.fontSize));
            } else if(t.dataset.strokeEnable==="true"){
                ctx.lineWidth=parseInt(t.dataset.strokeWidth); ctx.strokeStyle=t.dataset.strokeColor;
                ctx.strokeText(t.textContent,0,parseInt(s.fontSize));
            }
            ctx.fillStyle=s.color; ctx.fillText(t.textContent,0,parseInt(s.fontSize));
            ctx.restore();
        });
        const a=document.createElement("a"); a.href=c.toDataURL(); a.download="thumbnail.png"; a.click();
    };
</script>
